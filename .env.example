# AI Review Template - Environment Configuration

# === Required Secrets (add in Forgejo repo Settings → Secrets) ===

# Codeberg Personal Access Token with repo scope
CODEBERG_TOKEN=your-codeberg-pat-here

# Codeberg repository owner (username or organization)
REPO_OWNER=your-username

# Codeberg repository name
REPO_NAME=your-repo-name

# === Optional Environment Variables ===

# Polling interval (cron expression)
# Default: */10 * * * * (every 10 minutes)
POLLING_CRON=*/10 * * * *

# Ollama host URL
# For podman: http://host.containers.internal:11434
# For docker: http://host.docker.internal:11434
OLLAMA_HOST=http://host.containers.internal:11434

# Ollama model to use
# Must be pulled locally: ollama pull deepseek-coder:6.7b
OLLAMA_MODEL=deepseek-coder:6.7b

# Path to JSON state file (acts as database)
# Default: /data/reviewed_prs.json (in runner volume)
DB_PATH=/data/reviewed_prs.json